{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ionity-global-pty-ltd.github.io/ionity-assets/assets.schema.json",
  "title": "Ionity Assets Catalog",
  "type": "object",
  "required": ["name", "description", "repository", "homepage", "asset_count", "counts", "assets"],
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "repository": { "type": "string", "format": "uri" },
    "homepage": { "type": "string", "format": "uri" },
    "generated_at": { "type": "string", "format": "date-time" },
    "asset_count": { "type": "integer", "minimum": 0 },
    "counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "path", "category", "format", "bytes", "raw_url", "github_url"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "path": { "type": "string" },
          "category": { "enum": ["image", "video", "audio", "document", "metadata", "code", "archive", "other"] },
          "format": { "type": "string" },
          "bytes": { "type": "integer", "minimum": 0 },
          "raw_url": { "type": "string", "format": "uri" },
          "github_url": { "type": "string", "format": "uri" }
        },
        "additionalProperties": false
      }
    }
  }
}